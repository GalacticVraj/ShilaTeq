{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready|started server|Local:",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/product/inventory-qr",
        "http://localhost:3000/why/vs-tally-accounting",
        "http://localhost:3000/pricing",
        "http://localhost:3000/guides/dead-capital",
        "http://localhost:3000/faq",
        "http://localhost:3000/about",
        "http://localhost:3000/contact",
        "http://localhost:3000/legal/privacy"
      ],
      "numberOfRuns": 3,
      "settings": { "preset": "desktop" }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 1.0, "aggregationMethod": "median" }],
        "categories:seo": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:best-practices": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:performance": ["warn", { "minScore": 0.8, "aggregationMethod": "median" }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
